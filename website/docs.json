{
  "$schema": "https://holocron.so/docs.json",
  "name": "Playwriter",
  "description": "Docs for Playwriter, the CLI and MCP that lets agents control your real Chrome browser.",
  "logo": {
    "light": "/playwriter-logo.svg",
    "dark": "/playwriter-logo.svg",
    "href": "/"
  },
  "favicon": {
    "light": "/favicon-32.png",
    "dark": "/favicon-32.png"
  },
  "colors": {
    "primary": "#FF9500"
  },
  "knownPaths": ["/README"],
  "navigation": {
    "tabs": [
      {
        "tab": "Docs",
        "groups": [
          {
            "group": "Getting Started",
            "icon": "lucide:rocket",
            "pages": ["index", "docs/installation", "docs/cli", "docs/mcp-setup"]
          },
          {
            "group": "Guides",
            "icon": "lucide:book-open",
            "pages": ["docs/remote-access", "docs/troubleshooting"]
          },
          {
            "group": "Use Cases",
            "icon": "lucide:lightbulb",
            "pages": ["docs/use-cases"]
          },
          {
            "group": "Reference",
            "icon": "lucide:book-text",
            "pages": ["docs/skill"]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "icon": "github",
          "href": "https://github.com/remorses/playwriter",
          "placement": "tabs"
        },
        {
          "anchor": "Changelog",
          "icon": "lucide:logs",
          "href": "https://github.com/remorses/playwriter/releases",
          "placement": "tabs"
        }
      ]
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Chrome Extension",
        "href": "https://chromewebstore.google.com/detail/playwriter/jfeammnjpkecdekppnclgkkffahnhfhe"
      }
    ],
    "primary": {
      "label": "GitHub",
      "href": "https://github.com/remorses/playwriter"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/remorses/playwriter"
    }
  }
}
